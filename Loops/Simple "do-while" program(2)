#include <stdio.h>

int main() {
    int number;
    int sum = 0;

    // The loop body executes at least once before checking the condition
    do {
        printf("Enter a number (0 to stop): ");
        scanf("%d", &number);
        sum += number;
    } while (number != 0); // Condition is checked after the code block

    printf("The total sum is: %d\n", sum);

    return 0;
}
